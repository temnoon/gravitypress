{
  "name": "gravitypress",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "format": "prettier -w .",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "dev:web": "pnpm -C apps/web dev",
    "dev:worker": "pnpm -C apps/worker dev",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
